import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { Card, PageTitle, TextLinkButton } from "widgets.slint";
import { TagQueryData, JobData } from "types.slint";

component JobRow {
    in property <JobData> job;
    callback toggle-pause;

    // 0..=2 = Starting/Discovering/Downloading; animate dots only while active.
    property <bool> animate-label: root.job.phase <= 2;
    property <int> tick: 0;
    property <string> dots: root.animate-label
        ? (root.tick == 1 ? "." : root.tick == 2 ? ".." : root.tick == 3 ? "..." : "")
        : "";

    Timer {
        interval: 400ms;
        running: root.animate-label;
        triggered() => {
            root.tick = mod(root.tick + 1, 4);
        }
    }

    VerticalLayout {
        spacing: 6px;

        HorizontalLayout {
            spacing: 8px;

            Text {
                text: root.job.phase-label + root.dots;
                color: root.job.phase-color-idx == 0 ? Theme.text-muted
                    : (root.job.phase-color-idx == 2 ? Theme.success
                    : (root.job.phase-color-idx == 3 ? Theme.warn
                    : (root.job.phase-color-idx == 4 ? Theme.danger
                    : Theme.primary)));
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }

            Rectangle { horizontal-stretch: 1; }

            Text {
                text: root.job.stats-label;
                color: Theme.text-muted;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            if !root.job.finished : TextLinkButton {
                label: root.job.paused ? "Resume" : "Pause";
                clicked => { root.toggle-pause(); }
            }
        }

        Rectangle {
            height: 8px;
            border-radius: 4px;
            background: Theme.surface-container-high;
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width * root.job.progress;
                height: parent.height;
                border-radius: 4px;
                background: Theme.primary;
            }
        }

        if root.job.current-file != "" : Text {
            text: root.job.current-file;
            color: Theme.text-muted;
            font-size: 11px;
            overflow: elide;
        }
    }
}

component QueryCard {
    in property <TagQueryData> query;
    in property <[JobData]> jobs;
    in property <bool> logged-in;
    callback download-all;
    callback remove;
    callback cancel;
    callback toggle-pause-job(int);

    Card {
        VerticalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 14px;
            padding-bottom: 14px;
            spacing: 0px;

            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: root.query.tags;
                    color: Theme.text;
                    font-size: 16px;
                    font-weight: 700;
                    wrap: word-wrap;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                if root.query.running || root.query.queued : TextLinkButton {
                    label: "Cancel";
                    clicked => { root.cancel(); }
                }
                if !root.query.running && !root.query.queued : TextLinkButton {
                    label: "Remove";
                    clicked => { root.remove(); }
                }
                Button {
                    text: "Download";
                    primary: true;
                    enabled: !root.query.running && !root.query.queued && root.logged-in;
                    clicked => { root.download-all(); }
                }
            }

            if root.query.queued : VerticalLayout {
                padding-top: 4px;
                Text {
                    text: "queued — waiting for the active job";
                    color: Theme.warn;
                    font-size: 12px;
                }
            }

            if root.query.failed-count > 0 : VerticalLayout {
                padding-top: 4px;
                Text {
                    text: "\{root.query.failed-count} permanently skipped";
                    color: Theme.text-muted;
                    font-size: 12px;
                }
            }

            for job in root.jobs : VerticalLayout {
                spacing: 0px;
                if job.tags == root.query.tags : VerticalLayout {
                    spacing: 0px;
                    Rectangle { height: 10px; }
                    Rectangle { height: 1px; background: Theme.outline-variant; }
                    Rectangle { height: 10px; }
                    JobRow {
                        job: job;
                        toggle-pause => { root.toggle-pause-job(job.id); }
                    }
                }
            }
        }
    }
}

export component QueuePage inherits VerticalLayout {
    in property <[TagQueryData]> queries;
    in property <[JobData]> jobs;
    in property <bool> logged-in;
    in-out property <string> new-query-buf;
    callback remove-query(int);
    callback cancel-query(int);
    callback start-job(string);
    callback toggle-pause-job(int);

    padding-left: 32px;
    padding-right: 32px;
    padding-top: 32px;
    padding-bottom: 32px;
    spacing: 24px;

    PageTitle {
        title: "Queue";
        subtitle: "Type a tag search and download — saved queries can be re-run for new posts only.";
    }

    Card {
        vertical-stretch: 0;
        HorizontalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 14px;
            padding-bottom: 14px;
            spacing: 10px;
            LineEdit {
                placeholder-text: "tags (e.g. canine solo -young)";
                text <=> root.new-query-buf;
                accepted(s) => {
                    if (s != "" && root.logged-in) {
                        root.start-job(s);
                        root.new-query-buf = "";
                    }
                }
            }
            Button {
                text: "Download";
                primary: true;
                enabled: root.logged-in && root.new-query-buf != "";
                clicked => {
                    root.start-job(root.new-query-buf);
                    root.new-query-buf = "";
                }
            }
        }
    }

    if root.queries.length == 0 : Card {
        vertical-stretch: 1;
        VerticalLayout {
            padding-top: 32px;
            padding-bottom: 32px;
            alignment: center;
            spacing: 6px;
            Text {
                text: "No queries yet";
                color: Theme.text;
                font-size: 16px;
                font-weight: 700;
                horizontal-alignment: center;
            }
            Text {
                text: "Add a tag search above to get started.";
                color: Theme.text-muted;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }

    if root.queries.length > 0 : ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            alignment: start;
            spacing: 12px;
            for q in root.queries : QueryCard {
                query: q;
                jobs: root.jobs;
                logged-in: root.logged-in;
                download-all => { root.start-job(q.tags); }
                remove => { root.remove-query(q.id); }
                cancel => { root.cancel-query(q.id); }
                toggle-pause-job(id) => { root.toggle-pause-job(id); }
            }
        }
    }
}
